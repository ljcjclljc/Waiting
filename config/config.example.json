{
  "listeners": [
    { "address": "0.0.0.0", "port": 8080, "https": false }
  ],
  "app": {
    "number_of_threads": 0,
    "enable_session": false,
    "document_root": "./public",
    "upload_path": "/tmp/drogon-blog-uploads",
    "file_types": ["css", "js", "svg", "png", "jpg", "jpeg", "webp", "ico", "woff2"],
    "use_implicit_page": false,
    "use_gzip": true,
    "static_files_cache_time": 3600,
    "client_max_body_size": "256K",
    "log": { "log_level": "INFO", "display_local_time": true }
  },
  "custom_config": {
    "content_path": "./content/posts",
    "site": {
      "name": "向量笔记",
      "description": "用 C++ 记录系统、网络与工程实践",
      "url": "https://blog.example.com",
      "author": "YOUR_NAME",
      "github": {
        "repository_url": "https://github.com/OWNER/REPOSITORY",
        "branch": "main"
      },
      "giscus": {
        "enabled": true,
        "repo": "OWNER/REPOSITORY",
        "repo_id": "R_REPOSITORY_ID",
        "category": "Announcements",
        "category_id": "DIC_CATEGORY_ID"
      }
    }
  }
}
